#: src/Admin/SettingsPage.php:182
msgid "Show Ethiopian date alongside post published dates"
msgstr "ከልጥፍ ቀኖች ጋር የኢትዮጵያ ቀን ያሳዩ"

#: src/Admin/SettingsPage.php:183
msgid "Wires up a theme filter — display logic comes in a later step."
msgstr "የጭብጥ ማጣሪያ ያሰናዳል — ማሳያ ሎጂክ ቆይቶ ይታከላል።"

#: src/Rest/ConvertController.php:111
msgid "The provided date is not valid."
msgstr "የቀረበው ቀን ትክክለኛ አይደለም።"

#: src/Rest/ConvertController.php:135
msgid "date must be in YYYY-MM-DD format."
msgstr "ቀን በYYYY-MM-DD ቅርጸት መሆን አለበት።"

#: blocks/ethio-date/datepicker.js:158
msgid "Could not convert date. Please try a different date."
msgstr "ቀኑን መቀየር አልተቻለም። ሌላ ቀን ይሞክሩ።"

#: blocks/ethio-date/datepicker.js:179
msgid "Leap year — Pagumé has 6 days"
msgstr "ዘላፊ ዓ.ም. — ጳጉሜ 6 ቀናት አለው"

#: blocks/ethio-date/datepicker.js:180
