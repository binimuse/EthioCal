{
    "name": "binimusema/ethio-cal",
    "description": "Ethiopian (Ge'ez) calendar WordPress plugin",
    "type": "wordpress-plugin",
    "require": {
        "php": ">=8.1",
        "andegna/calender": "^2.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0",
        "wp-coding-standards/wpcs": "^3.3",
        "squizlabs/php_codesniffer": "^3.11"
    },
    "autoload": {
        "psr-4": {
            "EthioCal\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "EthioCal\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "phpcs",
        "i18n": "wp i18n make-pot . languages/binimuse-geez-calendar.pot --domain=binimuse-geez-calendar --exclude=vendor,node_modules,build,tests --package-name=\"Binimuse Geez Calendar\""
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
